# JWT kalit (productionda majburiy o'zgartiring)
JWT_SECRET=your-strong-secret-here
PORT=3000

# Ma'lumotlar papkasi (JSON + admin rasmlari). Productionda doimiy disk mount qiling.
# Masalan Docker: -v /var/lib/qadriyatlar/data:/app/server/data
# DATA_DIR=/app/server/data

# Bog'lanish formasi — xabarlar shu pochtaga keladi
CONTACT_TO=sizning@email.uz

# SMTP (Gmail, Mail.ru, hosting pochtasi)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=sizning@gmail.com
SMTP_PASS=app-parol-yoki-smtp-parol
SMTP_FROM="Qadriyatlar Kaledaskopi" <sizning@gmail.com>
